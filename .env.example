# Rural AI Assistant Backend — environment template
# Copy to .env and fill in values. Do not commit .env.

# AWS (DynamoDB, S3, Polly)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# PostgreSQL (full connection URL)
POSTGRES_URL=postgresql://user:password@localhost:5432/rural_ai

# S3
S3_BUCKET_NAME=rural-ai-audio

# DynamoDB (legacy sessions & chat)
DYNAMODB_TABLE_SESSIONS=rural_ai_sessions
DYNAMODB_TABLE_CHAT=rural_ai_chat_history

# DynamoDB service (users, sessions, messages, user_profiles) — region ap-south-1
DYNAMODB_REGION=ap-south-1
DYNAMODB_TABLE_USERS=users
DYNAMODB_TABLE_MESSAGES=messages
DYNAMODB_TABLE_USER_PROFILES=user_profiles

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Speech-to-Text: whisper (free) or google (requires billing)
STT_PROVIDER=whisper
WHISPER_MODEL_SIZE=base

# Google Speech-to-Text (only when STT_PROVIDER=google)
GOOGLE_APPLICATION_CREDENTIALS=

# Amazon Polly (optional, default: Joanna)
POLLY_VOICE_ID=Joanna

# Rural AI Assistant Backend — environment template
# Copy to .env and fill in values. Do not commit .env.

# AWS (DynamoDB, S3, Polly)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# PostgreSQL (full connection URL)
POSTGRES_URL=postgresql://user:password@localhost:5432/rural_ai

# S3
S3_BUCKET_NAME=rural-ai-audio

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google Speech-to-Text
GOOGLE_STT_API_KEY=
